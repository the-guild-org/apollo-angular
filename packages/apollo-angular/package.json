{
  "name": "apollo-angular",
  "version": "14.0.0",
  "type": "module",
  "description": "Use your GraphQL data in your Angular app, with the Apollo Client",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-guild-org/apollo-angular",
    "directory": "packages/apollo-angular"
  },
  "homepage": "https://www.apollo-angular.com/",
  "contributors": [
    {
      "name": "Kamil Kisiela",
      "email": "kamil.kisiela@gmail.com",
      "url": "https://github.com/kamilkisiela/"
    }
  ],
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "module": "build/fesm2020/ngApollo.mjs",
  "typings": "build/index.d.ts",
  "keywords": [
    "apollo",
    "graphql",
    "angular",
    "schematics",
    "angular-schematics"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json && pnpm build:schematics",
    "build:schematics": "tsc -p schematics/tsconfig.json && node ./scripts/move-schematics.js",
    "prebuild": "rm -rf build/",
    "release": "pnpm build && changeset publish",
    "test": "vitest --run && pnpm test:schematics",
    "test:schematics": "tsc -p schematics/tsconfig.test.json && node scripts/move-schematics.js && jasmine --config=schematics/jasmine.json"
  },
  "peerDependencies": {
    "@angular/core": "^19.0.0 || ^20.0.0 || ^21.0.0",
    "@apollo/client": "^4.0.1",
    "graphql": "^16.0.0",
    "rxjs": "^7.8.0"
  },
  "dependencies": {
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.1.1",
    "@analogjs/vitest-angular": "^2.1.1",
    "@angular-devkit/schematics": "^19.2.0",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/platform-server": "^19.2.0",
    "@types/jasmine": "^5.1.7",
    "@types/node": "^22.0.0",
    "jasmine": "^5.6.0",
    "jsdom": "^26.0.0",
    "ng-packagr": "^19.2.2",
    "typescript": "~5.8.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.14"
  },
  "publishConfig": {
    "directory": "build",
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "schematics": "./schematics/collection.json"
}
